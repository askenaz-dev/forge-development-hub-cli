{
  "realm": "fdh-dev",
  "enabled": true,
  "registrationAllowed": false,
  "loginTheme": "keycloak",
  "accessTokenLifespan": 1800,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "attributes": {
    "frontendUrl": "http://host.docker.internal:18088"
  },
  "groups": [
    { "name": "fdh-admins" },
    { "name": "fdh-publishers" },
    { "name": "fdh-reviewers" },
    { "name": "fdh-authors" }
  ],
  "users": [
    {
      "username": "admin@fdh.local",
      "email": "admin@fdh.local",
      "firstName": "Admin",
      "lastName": "User",
      "emailVerified": true,
      "enabled": true,
      "credentials": [{ "type": "password", "value": "admin", "temporary": false }],
      "groups": ["/fdh-admins"]
    },
    {
      "username": "author@fdh.local",
      "email": "author@fdh.local",
      "firstName": "Author",
      "lastName": "User",
      "emailVerified": true,
      "enabled": true,
      "credentials": [{ "type": "password", "value": "author", "temporary": false }],
      "groups": ["/fdh-authors"]
    },
    {
      "username": "consumer@fdh.local",
      "email": "consumer@fdh.local",
      "firstName": "Consumer",
      "lastName": "User",
      "emailVerified": true,
      "enabled": true,
      "credentials": [{ "type": "password", "value": "consumer", "temporary": false }]
    }
  ],
  "clients": [
    {
      "clientId": "fdh-portal",
      "name": "FDH Portal (local dev)",
      "enabled": true,
      "publicClient": false,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost:3000/api/auth/callback/keycloak",
        "http://localhost:3000/*",
        "http://host.docker.internal:3000/*"
      ],
      "webOrigins": ["http://localhost:3000", "http://host.docker.internal:3000"],
      "secret": "dev-secret",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "groups"
          }
        },
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ]
}
