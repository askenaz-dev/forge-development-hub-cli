# -----------------------------------------------------------------------------
# Go build output
# -----------------------------------------------------------------------------
/bin/
/dist/
/release/
*.exe
*.test
*.out
*.tar.gz
*.sha256
/vendor/
coverage.out
coverage.html
profile.out

# -----------------------------------------------------------------------------
# npm wrapper (npm/) build artifacts
# -----------------------------------------------------------------------------
# Source is TypeScript under npm/src/; tsc compiles to npm/dist/ which we
# don't track — it's regenerated on every `npm run build`. The published
# tarball contains npm/dist/ (via package.json "files" allowlist).
npm/dist/
npm/coverage/
npm/.vitest/

# -----------------------------------------------------------------------------
# Node / Next.js (web/)
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.*
.yarn/install-state.gz

# Next.js build artifacts
web/.next/
web/out/
web/.swc/
web/.turbo/
web/tsconfig.tsbuildinfo
web/next-env.d.ts

# Playwright + axe-core artifacts
web/test-results/
web/playwright-report/
web/playwright/.cache/
web/blob-report/

# pnpm / npm / yarn debug logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.pnpm-store/

# Local env overrides
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.dockerignore.local

# -----------------------------------------------------------------------------
# Editor / OS
# -----------------------------------------------------------------------------
.idea/
.vscode/
.DS_Store
Thumbs.db
*.swp
*~
desktop.ini

# -----------------------------------------------------------------------------
# Local-only artifacts
# -----------------------------------------------------------------------------
*.local
/tmp/
