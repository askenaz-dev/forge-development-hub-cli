# Next.js 14 has runtime dependencies it expects to resolve at the top
# of node_modules. pnpm's strict isolation hides them. We turn on
# shamefully-hoist for this app — Next.js + a Docker build is one of the
# canonical cases the flag exists for. Strict isolation can come back
# when Next.js drops its implicit dependency model.
shamefully-hoist=true
auto-install-peers=true
